{
  "$schema": "https://stryker-mutator.io/schemas/stryker-schema.json#",
  "testRunner": "jest",
  "testRunnerNodeArgs": ["--experimental-vm-modules"],
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "reporters": ["json"],
  "dashboard": {
    "project": "github.com/bmordue/questionnaire",
    "version": "main",
    "baseUrl": "https://dashboard.stryker-mutator.io/",
    "reportType": "full"
  },
  "coverageAnalysis": "perTest",
  "ignoreStatic": true,
  "mutate": [
    "src/markdown-convert.ts",
    "!src/**/__tests__/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.d.ts"
  ]
}
